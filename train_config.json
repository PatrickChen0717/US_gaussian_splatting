{
  "image_dir": "spine_data/left1/images.npy",
  "poses": "spine_data/left1/poses.npy",
  "image_dir_val": null,
  "pose_val": null,
  "output": "outputs/checkpoints/vanilla_gaussians.pt",
  "device": "cuda",

  "height": 400,
  "width": 148,
  "grayscale": true,
  "image_value_scale": 255.0,
  "pixel_spacing_x": 1.0,
  "pixel_spacing_y": 1.0,
  "slice_thickness": 1.0,

  "num_gaussians": 30000,
  "init": "svrtk",
  "svrtk_fill_fraction": 0.3,
  "svrtk_fill_opacity": 0.05,
  "svrtk_fill_endpoint_margin": 0.1,
  "covariance_mode": "ultrasound_psf",
  "initial_scale_x": 1.0,
  "initial_scale_y": 0.5,
  "initial_scale_z": 2.0,
  "initial_opacity": 0.5,
  "initial_transmittance": 0.99,

  "renderer_backend": "ultragray_cuda",
  "ultragray_repo_path": "../UltraG-Ray",
  "cuda_tile_size_x": 4,
  "cuda_tile_size_y": 128,
  "native_pose_convention": "camera_to_world",
  "native_ultragray_exact": true,
  "native_ultragray_loader_exact": true,
  "native_global_scale": 1.0,
  "native_init_extent": 0.8,
  "native_init_scale": 0.05,
  "native_grow_scale3d": 0.01,
  "native_prune_scale3d": 0.1,
  "native_prune_scale3d_min": 0.00001,
  "random_seed": 42,
  "pose_sideways_noise": 0.0,
  "pose_frontback_noise": 0.2,
  "pose_updown_noise": 0.0,

  "shadowing": true,
  "shadow_strength": 1.0,
  "render_chunk_size": 16,
  "max_visible_gaussians_per_slice": null,

  "steps": 500,
  "batch_size": 8,
  "lr": 0.01,
  "means_lr": 0.0001,
  "scales_lr": 0.005,
  "quats_lr": 0.005,
  "transmittances_lr": 0.0005,
  "intensity_lr": 0.005,
  "sh_rest_lr": 0.00001,
  "lr_final_factor": 0.1,
  "sh_degree": 1,
  "sh_degree_interval": 1000,
  "ultrasound_edges_weight": 0.8,
  "l1_weight": 0.5,
  "scale_prior_weight": 0.001,
  "opacity_sparsity_weight": 0.0,
  "ssim_weight": 0.2
}
